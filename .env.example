# ============================================================
# SAA29 – Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o arquivo .env no Git.
# ============================================================

# --- Banco de Dados ---
# SQLite é o banco padrão para instalação local/monousuário.
# Para PostgreSQL em produção, descomente a linha abaixo e comente a de SQLite.
DATABASE_URL=sqlite+aiosqlite:///./saa29_local.db
# DATABASE_URL=postgresql+asyncpg://saa29_user:senha_segura@localhost:5432/saa29_db

# --- Aplicação ---
APP_ENV=development          # development | production
APP_DEBUG=True
APP_SECRET_KEY=TROQUE_POR_UMA_CHAVE_SECRETA_LONGA_E_ALEATORIA
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=BisKP76pg3IU

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480       # 8 horas

# --- Upload e Storage ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
STORAGE_BACKEND=local # local | r2

# --- Cloudflare R2 (Descomente para usar storage R2) ---
# R2_ACCOUNT_ID=sua_account_id
# R2_ACCESS_KEY_ID=sua_access_key
# R2_SECRET_ACCESS_KEY=sua_secret_key
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_BUCKET_NAME=saa29-storage

# --- PostgreSQL (Docker) – Descomente caso use PostgreSQL ---
# POSTGRES_USER=saa29_user
# POSTGRES_PASSWORD=senha_segura
# POSTGRES_DB=saa29_db
